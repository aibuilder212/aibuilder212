# ================================================================
# Agent Zero Docker Configuration
# ================================================================
# Copy this file to .env and fill in your API keys and password.
#
# Mount into the container:
#   docker run ... -v /path/to/this/.env:/a0/.env ...
# or use docker-compose (see docker-compose.yml).
#
# Keys are stored with the pattern:  API_KEY_<PROVIDER_ID_UPPERCASE>
# Settings are stored with the pattern: A0_SET_<setting_name>
# ================================================================

# ----------------------------------------------------------------
# Authentication  (required - protects the web UI)
# ----------------------------------------------------------------
AUTH_LOGIN=admin
AUTH_PASSWORD=change_me_please

# ----------------------------------------------------------------
# API Keys
# ----------------------------------------------------------------

# OpenAI – GPT-4o
# Get yours at: https://platform.openai.com/api-keys
API_KEY_OPENAI=sk-...your-openai-key-here...

# Google – Gemini
# Get yours at: https://aistudio.google.com/app/apikey
API_KEY_GOOGLE=AIza...your-google-key-here...

# Groq – fast LLaMA inference
# Get yours at: https://console.groq.com/keys
# (create a new key under your aibuilder212 account, allow all repos)
API_KEY_GROQ=gsk_...your-groq-key-here...

# ----------------------------------------------------------------
# Chat Model  →  GPT-4o  (OpenAI)
# ----------------------------------------------------------------
A0_SET_chat_model_provider=openai
A0_SET_chat_model_name=gpt-4o
A0_SET_chat_model_vision=true
A0_SET_chat_model_ctx_length=128000

# ----------------------------------------------------------------
# Utility Model  →  Gemini 3 Flash  (Google)
# Handles memory, summarisation and internal prompts.
# Fast and cost-efficient – perfect for utility work.
# ----------------------------------------------------------------
A0_SET_util_model_provider=google
A0_SET_util_model_name=gemini-3-flash-preview
A0_SET_util_model_ctx_length=1000000

# ----------------------------------------------------------------
# Browser / Vision Model  →  GPT-4o  (OpenAI, vision enabled)
# ----------------------------------------------------------------
A0_SET_browser_model_provider=openai
A0_SET_browser_model_name=gpt-4o
A0_SET_browser_model_vision=true

# ----------------------------------------------------------------
# Embedding Model  (local HuggingFace – no API key required)
# ----------------------------------------------------------------
A0_SET_embed_model_provider=huggingface
A0_SET_embed_model_name=sentence-transformers/all-MiniLM-L6-v2

# ----------------------------------------------------------------
# Alternative: swap chat model to Groq for faster / cheaper runs
# ----------------------------------------------------------------
# A0_SET_chat_model_provider=groq
# A0_SET_chat_model_name=llama-3.3-70b-versatile
# A0_SET_chat_model_ctx_length=32768
# A0_SET_chat_model_vision=false

# ----------------------------------------------------------------
# Root password for the Docker container (optional, for SSH access)
# ----------------------------------------------------------------
# ROOT_PASSWORD=change_me_too
